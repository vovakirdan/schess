pragma module::chess;

pub fn perft(game: &Game, depth: int) -> int {
    if depth <= 0 {
        return 1;
    }

    let moves = legal_moves(game);
    if depth == 1 {
        return moves.__len() to int;
    }

    let mut total = 0;
    for mv in moves {
        compare apply_move(game, mv) {
            nothing => {};
            Some(next) => {
                total = total + perft(&next, depth - 1);
            };
        };
    }
    return total;
}
