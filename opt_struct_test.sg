type Point = { x: int, y: int }

@entrypoint
fn main() -> int {
    let mut arr: Option<Point>[2] = [nothing, nothing];
    arr[0] = Some(Point { x = 1, y = 2 });
    arr[1] = Some(Point { x = 3, y = 4 });

    let a = compare arr[0] {
        nothing => 0;
        Some(p) => p.x + p.y;
    };
    let b = compare arr[1] {
        nothing => 0;
        Some(p) => p.x * 10 + p.y;
    };

    print("a=" + (a to string) + " b=" + (b to string));
    return a + b;
}

